# =============================================
#   Discord Bot — Environment Configuration
# =============================================

# Your bot token from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# Your Discord application/client ID
CLIENT_ID=your_client_id_here

# The guild (server) ID where the bot operates
GUILD_ID=your_guild_id_here

# ── Channel IDs ────────────────────────────────
# Channel where the daily schedule is posted
SCHEDULE_CHANNEL_ID=your_schedule_channel_id

# Channel where session summaries are posted
SESSION_CHANNEL_ID=your_session_channel_id

# Channel that shows the member status board (green/red)
MEMBER_STATUS_CHANNEL_ID=your_member_status_channel_id

# ── Role ───────────────────────────────────────
# Only members with this role will appear on the status board
TRACKED_ROLE_ID=your_role_id_here

# ── Timezone ───────────────────────────────────
# Timezone for midnight cron job (e.g. Europe/Lisbon, America/New_York)
TIMEZONE=Europe/Lisbon
