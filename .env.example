# =============================================
#   Discord Bot — Environment Configuration
# =============================================

BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Canal onde a marcação diária é publicada
SCHEDULE_CHANNEL_ID=your_schedule_channel_id

# Role a pingar no final da marcação
ORG_ROLE_ID=your_org_role_id

# Timezone para o cron das 00:00 (ex: Europe/Lisbon)
TIMEZONE=Europe/Lisbon
